<div class="serverHeader">
  <div class="serverHeader__stripe serverHeader__stripe--live">Live</div>
  <div class="serverHeader__info">
    <div class="serverHeader__title">Mail Server</div>
    <ul class="serverHeader__list">
      <li class="serverHeader__list--ok">&check; Outgoing messages</li>
      <li class="serverHeader__list--ok">&check; All domains verified</li>
    </ul>
  </div>
  <div class="serverHeader__stats">
    <ul class="serverHeader__statsList">
      <li><strong>0</strong> Held</li>
      <li><strong>0</strong> Queue</li>
      <li><strong><%= stats.bounces || 0 %></strong> Bounces</li>
      <li><strong>active</strong> Status</li>
    </ul>
  </div>
  <div class="serverHeader__usage">
    <div class="serverHeader__usageTitle">Monthly usage</div>
    <div class="serverHeader__usageLine">
      <span class="serverHeader__usageLineLabel">Sent</span>
      <span class="serverHeader__usageLineBar"><span class="bar"><span class="bar__inner" style="width:<%= Math.min(100, (stats.messagesSent || 0) / 1000 * 100) %>%"></span></span></span>
      <span class="serverHeader__usageLineValue"><%= stats.messagesSent || 0 %></span>
    </div>
    <div class="serverHeader__usageLine">
      <span class="serverHeader__usageLineLabel">Daily avg</span>
      <span class="serverHeader__usageLineBar"><span class="bar"><span class="bar__inner" style="width:<%= Math.min(100, (stats.dailyAverage || 0) / 50 * 100) %>%"></span></span></span>
      <span class="serverHeader__usageLineValue"><%= stats.dailyAverage || 0 %></span>
    </div>
    <div class="serverHeader__usageLine">
      <span class="serverHeader__usageLineLabel">Limit</span>
      <span class="serverHeader__usageLineValueLarge">Unlimited <b>&rarr;</b></span>
    </div>
  </div>
</div>

<nav class="navBar">
  <ul>
    <li class="navBar__item"><a href="/portal/dashboard" class="navBar__link is-active">Overview</a></li>
    <li class="navBar__item navBar__item--end"><a href="/portal/messages" class="navBar__link">View all messages</a></li>
  </ul>
</nav>

<div class="pageContent">
  <% if (typeof messages !== 'undefined' && messages.length > 0) { %>
    <div class="mailGraph u-margin">
      <ul class="mailGraph__key">
        <li class="mailGraph__key--out">Outgoing Messages</li>
        <li>Incoming Messages</li>
      </ul>
      <div class="mailGraph__graph" data-chart="Line" data-chart-data='<%= JSON.stringify({labels:["Mon","Tue","Wed","Thu","Fri","Sat","Sun"],series:[[<%= stats.graphOutgoing || "0,0,0,0,0,0,0" %>],[<%= stats.graphIncoming || "0,0,0,0,0,0,0" %>]]}) %>' data-chart-options='{"showPoint":false,"lineSmooth":false,"axisX":{"showLabel":true},"axisY":{"showLabel":false}}'></div>
      <ul class="mailGraph__labels">
        <li>Last 7 days &rarr;</li>
        <li>Today</li>
      </ul>
    </div>

    <div class="titleWithLinks u-margin">
      <h2 class="titleWithLinks__title">Recently processed e-mails</h2>
      <ul class="titleWithLinks__links">
        <li><a href="/portal/messages" class="titleWithLinks__link">View full e-mail history</a></li>
      </ul>
    </div>

    <div class="messageList">
      <% recentMessages.forEach(function(msg) { %>
        <div class="messageList__message">
          <a href="/portal/messages/<%= msg.id %>" class="messageList__link">
            <div class="messageList__details messageList__details--outgoing">
              <div class="messageList__subject"><%= msg.subject || '(no subject)' %></div>
              <dl class="messageList__addresses">
                <dt>To:</dt><dd><%= msg.rcpt_to %></dd>
                <dt>From:</dt><dd><%= msg.mail_from %></dd>
              </dl>
            </div>
            <div class="messageList__meta">
              <div class="messageList__timestamp"><%= msg.created_at %></div>
              <div class="messageList__status"><span class="label label--messageStatus-<%= msg.status %>"><%= msg.status %></span></div>
            </div>
          </a>
        </div>
      <% }) %>
    </div>
  <% } else { %>
    <div class="pageContent--compact">
      <div class="noData noData--clean">
        <h2 class="noData__title">Your new mail server is ready to go.</h2>
        <p class="noData__text">Check out the information below to get started sending &amp; receiving e-mail through your new mail server.</p>
        <div class="noData__button buttonSet buttonSet--center">
          <a href="/portal/domains" class="button">Read about sending e-mail</a>
          <a href="/portal/settings" class="button">Configure your server</a>
        </div>
      </div>
    </div>
  <% } %>
</div>
