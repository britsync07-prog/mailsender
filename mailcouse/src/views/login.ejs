<% if (typeof error !== 'undefined' && error) { %>
  <div class="loginForm__error"><%= error %></div>
<% } %>

<form action="/<%= mode %>" method="POST">
  <% if (mode === 'signup') { %>
  <div class="loginForm__input">
    <label for="name">Full Name</label>
    <input type="text" id="name" name="name" required placeholder="Your name">
  </div>
  <% } %>
  <div class="loginForm__input">
    <label for="email">Email address</label>
    <input type="email" id="email" name="email" required placeholder="you@example.com" autofocus>
  </div>
  <div class="loginForm__input">
    <label for="password">Password</label>
    <input type="password" id="password" name="password" required placeholder="Password" minlength="8">
  </div>
  <div class="loginForm__submit">
    <button type="submit" class="button button--full">
      <%= mode === 'login' ? 'Sign In' : 'Create Account' %>
    </button>
  </div>
</form>

<div class="loginForm__divider"></div>
<p class="loginForm__localTitle">
  <% if (mode === 'login') { %>
    Don't have an account? <a href="/signup" class="u-link">Sign up</a>
  <% } else { %>
    Already have an account? <a href="/login" class="u-link">Sign in</a>
  <% } %>
</p>
