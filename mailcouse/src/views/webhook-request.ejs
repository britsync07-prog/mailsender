<div class="pageHeader">
  <div class="pageHeader__title">
    <span class="pageHeader__titlePrevious">Webhooks &rarr; History &rarr;</span>
    Request Details
  </div>
</div>

<nav class="navBar navBar--secondary">
  <ul>
    <li class="navBar__item"><a href="/portal/webhooks" class="navBar__link">Manage Webhooks</a></li>
    <li class="navBar__item"><a href="/portal/webhooks/history" class="navBar__link">History</a></li>
    <li class="navBar__item"><a href="/portal/webhooks/history/<%= req.uuid || req.id %>" class="navBar__link is-active">Request</a></li>
  </ul>
</nav>

<div class="pageContent pageContent--compact">
  <div class="tabular">
    <h3 style="font-size:16px;font-weight:600;margin-bottom:15px;">Webhook Request</h3>
    <table class="table">
      <tbody>
        <tr><th style="width:200px">UUID</th><td><%= req.uuid || req.id %></td></tr>
        <tr><th>Event</th><td><%= req.event || 'webhook' %></td></tr>
        <tr><th>URL</th><td><%= req.url || req.endpoint_url %></td></tr>
        <tr><th>Status Code</th><td><span class="label label--http-status-<%= String(req.status_code || req.status)[0] %>"><%= req.status_code || req.status %></span></td></tr>
        <tr><th>Timestamp</th><td><%= new Date(req.timestamp || req.created_at).toLocaleString() %></td></tr>
        <% if (req.time) { %><tr><th>Time</th><td><%= req.time %>s</td></tr><% } %>
        <% if (req.log_id) { %><tr><th>Log ID</th><td><%= req.log_id %></td></tr><% } %>
      </tbody>
    </table>
  </div>

  <% if (req.request_body || req.response_body) { %>
    <div class="tabular u-margin">
      <% if (req.request_body) { %>
        <h3 style="font-size:14px;font-weight:600;margin-bottom:10px;">Request Body</h3>
        <pre class="mono" style="background:#f5f5f5;padding:12px;border-radius:3px;font-size:12px;white-space:pre-wrap;word-break:break-all;"><%= req.request_body %></pre>
      <% } %>
      <% if (req.response_body) { %>
        <h3 style="font-size:14px;font-weight:600;margin-bottom:10px;margin-top:20px;">Response Body</h3>
        <pre class="mono" style="background:#f5f5f5;padding:12px;border-radius:3px;font-size:12px;white-space:pre-wrap;word-break:break-all;"><%= req.response_body %></pre>
      <% } %>
    </div>
  <% } %>
</div>
