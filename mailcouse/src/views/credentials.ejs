<div class="pageHeader">
  <div class="pageHeader__title">SMTP Credentials</div>
</div>

<nav class="navBar">
  <ul>
    <li class="navBar__item"><a href="/portal/credentials" class="navBar__link is-active">Credentials</a></li>
    <li class="navBar__item navBar__item--end">
      <a href="javascript:showAddCredential()" class="navBar__link">+ New Credential</a>
    </li>
  </ul>
</nav>

<div class="pageContent pageContent--compact">
  <% if (credentials.length === 0) { %>
    <div class="noData noData--clean">
      <h2 class="noData__title">There are no credentials for this server.</h2>
      <p class="noData__text">In order to authenticate to your mail server, you use credentials. Once you've added a credential, you'll have a unique token which you can use to authenticate against our SMTP service or our HTTP API.</p>
      <div class="noData__button"><a href="javascript:showAddCredential()" class="button button--positive">Add your first credential</a></div>
    </div>
  <% } else { %>
    <p class="pageContent__intro u-margin">In order to authenticate to your mail server, you use credentials. Once you've added a credential, you'll have a unique token which you can use to authenticate against our SMTP service or our HTTP API.</p>
    <p class="u-margin pageContent__helpLink"><a href="/portal/help/outgoing" class="u-link">Read more about sending outgoing e-mails</a></p>

    <ul class="credentialList u-margin">
      <% credentials.forEach(function(c) { %>
        <li class="credentialList__item">
          <a href="javascript:void(0)" class="credentialList__link">
            <div class="credentialList__type">
              <span class="label label--credentialType-<%= c.type %>"><%= c.type %></span>
            </div>
            <div class="credentialList__properties">
              <p class="credentialList__name">
                <%= c.name %>
                <% if (c.hold) { %><span class="label label--red">Holding</span><% } %>
              </p>
              <p class="credentialList__key"><%= c.username %></p>
            </div>
            <div class="credentialList__usedAt">
              <% if (c.last_used_at) { %>
                <span class="credentialList__usedAtTitle">SMTP</span>
                <p>Used <%= c.last_used_at %></p>
              <% } else { %>
                <p>Not been used yet</p>
              <% } %>
            </div>
          </a>
        </li>
      <% }) %>
    </ul>

    <p class="u-center buttonSet buttonSet--center">
      <a href="javascript:showAddCredential()" class="button button--positive">Add another credential</a>
    </p>
  <% } %>
</div>

<div id="credential-modal" class="modal" style="display:none">
  <div class="modal__backdrop" onclick="hideAddCredential()"></div>
  <div class="modal__content">
    <div class="modal__header">New SMTP Credential</div>
    <div class="modal__body">
      <div class="formBlock">
        <label>Name</label>
        <input type="text" id="new-cred-name" placeholder="My App" class="input input--text">
      </div>
      <div id="new-cred-result" style="display:none">
        <p style="color:var(--orange);font-weight:600;margin-bottom:8px;">Save these credentials — the password won't be shown again.</p>
        <div class="credDisplay">
          <label>Username</label>
          <code id="cred-username"></code>
          <label>Password</label>
          <code id="cred-password"></code>
        </div>
        <p style="color:#666;font-size:12px;margin-top:10px;">Server: <strong>live.noblecircle.online</strong> &middot; Port: <strong>587</strong> (STARTTLS) / <strong>25</strong> (plain)</p>
      </div>
    </div>
    <div class="modal__footer">
      <button class="button button--neutral" onclick="hideAddCredential()">Cancel</button>
      <button class="button button--positive" id="add-cred-btn" onclick="addCredential()">Create</button>
    </div>
  </div>
</div>

<script>
function showAddCredential() { document.getElementById('credential-modal').style.display = 'flex'; }
function hideAddCredential() { document.getElementById('credential-modal').style.display = 'none'; }
async function addCredential() {
  var n = document.getElementById('new-cred-name').value.trim();
  if (!n) return alert('Enter a name');
  var btn = document.getElementById('add-cred-btn');
  btn.disabled = true; btn.textContent = 'Creating...';
  try {
    var r = await fetch('/api/portal/credentials', { method: 'POST',
      headers: { 'Content-Type':'application/json','Authorization':'Bearer <%= token %>' },
      body: JSON.stringify({ name: n })
    });
    var data = await r.json();
    if (!r.ok) return alert(data.error);
    document.getElementById('cred-username').textContent = data.username;
    document.getElementById('cred-password').textContent = data.password;
    document.getElementById('new-cred-result').style.display = 'block';
    document.getElementById('new-cred-name').disabled = true;
    btn.textContent = 'Close';
    btn.onclick = function() { location.reload(); };
  } catch(e) { alert('Error: ' + e.message); btn.disabled = false; btn.textContent = 'Create'; }
}
</script>
