<div class="pageHeader">
  <div class="pageHeader__title">SMTP Credentials</div>
</div>

<nav class="navBar">
  <ul>
    <li class="navBar__item"><a href="/portal/credentials" class="navBar__link is-active">Credentials</a></li>
    <li class="navBar__item navBar__item--end">
      <a href="javascript:showAddCredential()" class="navBar__link">+ New Credential</a>
    </li>
  </ul>
</nav>

<div class="pageContent pageContent--sidebar">
  <div class="credentialList">
    <% if (credentials.length === 0) { %>
      <div class="noData">
        <div class="noData__title">No credentials</div>
        <div class="noData__text">Create SMTP credentials to start sending email.</div>
        <div class="noData__button">
          <a href="javascript:showAddCredential()" class="button">New Credential</a>
        </div>
      </div>
    <% } %>
    <% credentials.forEach(function(c) { %>
      <div class="credentialList__item">
        <div class="credentialList__link">
          <div class="credentialList__type">
            <span class="label label--blue"><%= c.type %></span>
          </div>
          <div class="credentialList__properties">
            <div class="credentialList__name">
              <%= c.name %>
              <% if (c.hold) { %><span class="label label--red">On Hold</span><% } %>
            </div>
            <div class="credentialList__key"><%= c.username %></div>
          </div>
          <% if (c.last_used_at) { %>
            <div class="credentialList__usedAt">
              <span class="credentialList__usedAtTitle">Last used</span>
              <time><%= c.last_used_at %></time>
            </div>
          <% } %>
        </div>
      </div>
    <% }) %>
  </div>
</div>

<!-- New Credential Modal -->
<div id="credential-modal" class="modal" style="display:none">
  <div class="modal__backdrop" onclick="hideAddCredential()"></div>
  <div class="modal__content">
    <div class="modal__header">New SMTP Credential</div>
    <div class="modal__body">
      <div class="formBlock">
        <label>Name</label>
        <input type="text" id="new-cred-name" placeholder="My App">
      </div>
      <div id="new-cred-result" style="display:none">
        <p style="color:var(--orange);font-weight:600;margin-bottom:8px;">Save these credentials — the password won't be shown again.</p>
        <div class="credDisplay">
          <label>Username</label>
          <code id="cred-username"></code>
          <label>Password</label>
          <code id="cred-password"></code>
        </div>
        <p style="color:#666;font-size:12px;margin-top:10px;">
          Server: <strong>live.noblecircle.online</strong> &middot;
          Port: <strong>587</strong> (STARTTLS) / <strong>25</strong> (plain)
        </p>
      </div>
    </div>
    <div class="modal__footer">
      <button class="button button--neutral" onclick="hideAddCredential()">Cancel</button>
      <button class="button" id="add-cred-btn" onclick="addCredential()">Create</button>
    </div>
  </div>
</div>

<script>
function showAddCredential() { document.getElementById('credential-modal').style.display = 'flex'; }
function hideAddCredential() { document.getElementById('credential-modal').style.display = 'none'; }

async function addCredential() {
  var name = document.getElementById('new-cred-name').value.trim();
  if (!name) return alert('Enter a name');
  var btn = document.getElementById('add-cred-btn');
  btn.disabled = true; btn.textContent = 'Creating...';
  try {
    var res = await fetch('/api/portal/credentials', { method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer <%= token %>' },
      body: JSON.stringify({ name: name })
    });
    var data = await res.json();
    if (!res.ok) return alert(data.error);
    document.getElementById('cred-username').textContent = data.username;
    document.getElementById('cred-password').textContent = data.password;
    document.getElementById('new-cred-result').style.display = 'block';
    document.getElementById('new-cred-name').disabled = true;
    btn.textContent = 'Close';
    btn.onclick = function() { location.reload(); };
  } catch(e) { alert('Error: ' + e.message); btn.disabled = false; btn.textContent = 'Create'; }
}
</script>
