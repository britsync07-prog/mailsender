<div class="page-header">
  <h2>SMTP Credentials</h2>
  <button class="btn btn-primary" onclick="showAddCredential()">New Credential</button>
</div>

<div class="card">
  <table class="table">
    <thead>
      <tr>
        <th>Name</th>
        <th>Username</th>
        <th>Type</th>
        <th>Domain</th>
        <th>Hold</th>
        <th>Last Used</th>
        <th>Created</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% if (credentials.length === 0) { %>
        <tr><td colspan="8" class="empty">No SMTP credentials yet.</td></tr>
      <% } %>
      <% credentials.forEach(function(c) { %>
        <tr>
          <td><%= c.name %></td>
          <td class="mono"><%= c.username %></td>
          <td><%= c.type %></td>
          <td><%= c.domain_name || '—' %></td>
          <td><%= c.hold ? 'Yes' : 'No' %></td>
          <td><%= c.last_used_at || '—' %></td>
          <td><%= c.created_at %></td>
          <td><button class="btn btn-sm btn-danger" onclick="deleteCredential('<%= c.id %>')">Revoke</button></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<div id="credential-modal" class="modal" style="display:none">
  <div class="modal-backdrop" onclick="hideAddCredential()"></div>
  <div class="modal-content">
    <h3>New SMTP Credential</h3>
    <div class="form-group">
      <label>Name</label>
      <input type="text" id="new-cred-name" placeholder="My App">
    </div>
    <div id="new-cred-result" style="display:none">
      <h4>Credentials Created</h4>
      <p>Save these — the password won't be shown again.</p>
      <div class="cred-display">
        <label>Username</label>
        <code id="cred-username"></code>
        <label>Password</label>
        <code id="cred-password"></code>
      </div>
      <p class="muted">Server: <strong>live.noblecircle.online</strong> | Port: <strong>587</strong> (TLS) / <strong>25</strong> (plain)</p>
    </div>
    <div class="form-actions">
      <button class="btn" onclick="hideAddCredential()">Cancel</button>
      <button class="btn btn-primary" id="add-cred-btn" onclick="addCredential()">Create</button>
    </div>
  </div>
</div>

<script>
function showAddCredential() { document.getElementById('credential-modal').style.display = 'flex'; }
function hideAddCredential() { document.getElementById('credential-modal').style.display = 'none'; }

async function addCredential() {
  const name = document.getElementById('new-cred-name').value.trim();
  if (!name) return alert('Enter a name');
  const btn = document.getElementById('add-cred-btn');
  btn.disabled = true; btn.textContent = 'Creating...';
  try {
    const res = await fetch('/api/portal/credentials', { method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer <%= token %>' },
      body: JSON.stringify({ name })
    });
    const data = await res.json();
    if (!res.ok) return alert(data.error);
    document.getElementById('cred-username').textContent = data.username;
    document.getElementById('cred-password').textContent = data.password;
    document.getElementById('new-cred-result').style.display = 'block';
    document.getElementById('new-cred-name').disabled = true;
    btn.textContent = 'Close';
    btn.onclick = () => location.reload();
  } catch(e) { alert('Error: ' + e.message); btn.disabled = false; btn.textContent = 'Create'; }
}

async function deleteCredential(id) {
  if (!confirm('Revoke this credential?')) return;
  await fetch('/api/portal/credentials/' + id, { method: 'DELETE',
    headers: { 'Authorization': 'Bearer <%= token %>' }
  });
  location.reload();
}
</script>
