<div class="pageHeader">
  <div class="pageHeader__title">Message</div>
</div>

<nav class="navBar">
  <ul>
    <li class="navBar__item"><a href="/portal/messages" class="navBar__link">Messages</a></li>
    <li class="navBar__item"><a href="/portal/messages/<%= msg.id %>" class="navBar__link is-active">#<%= msg.id.substring(0,8) %></a></li>
  </ul>
</nav>

<div class="pageContent pageContent--sidebar">

  <div class="tabular">
    <h3 style="font-size:16px;font-weight:600;margin-bottom:15px;">Details</h3>
    <table class="dataTable">
      <tr><th style="width:140px;">ID</th><td class="mono"><%= msg.id %></td></tr>
      <tr><th>From</th><td><%= msg.mail_from %></td></tr>
      <tr><th>To</th><td><%= msg.rcpt_to %></td></tr>
      <tr><th>Subject</th><td><%= msg.subject || '(none)' %></td></tr>
      <tr><th>Status</th><td><span class="label label--<%= msg.status === 'sent' ? 'green' : msg.status === 'bounced' ? 'red' : 'orange' %>"><%= msg.status %></span></td></tr>
      <tr><th>Bounce</th><td><%= msg.bounce || '—' %></td></tr>
      <tr><th>Size</th><td><%= msg.size ? (msg.size/1024).toFixed(1) + ' KB' : '—' %></td></tr>
      <tr><th>Credential</th><td><%= msg.credential_name || '—' %></td></tr>
      <tr><th>Domain</th><td><%= msg.domain_name || '—' %></td></tr>
      <tr><th>Subdomain</th><td><span class="mono"><%= msg.subdomain || '—' %></span></td></tr>
      <tr><th>Created</th><td><%= msg.created_at %></td></tr>
      <tr><th>Sent At</th><td><%= msg.sent_at || '—' %></td></tr>
    </table>
  </div>

  <% if (msg.raw_headers) { %>
  <div class="tabular" style="margin-top:20px;">
    <h3 style="font-size:16px;font-weight:600;margin-bottom:15px;">Raw Headers</h3>
    <pre class="mono" style="background:#f5f5f5;padding:12px;border-radius:3px;font-size:12px;overflow-x:auto;white-space:pre-wrap;word-break:break-all;"><%= msg.raw_headers %></pre>
  </div>
  <% } %>

</div>
