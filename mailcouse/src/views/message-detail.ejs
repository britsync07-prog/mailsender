<div class="pageHeader">
  <div class="pageHeader__title">Message #<%= msg.id.substring(0,8) %></div>
</div>

<nav class="navBar navBar--secondary">
  <ul>
    <li class="navBar__item"><a href="/portal/messages/<%= msg.scope || 'outgoing' %>" class="navBar__link"><%= msg.scope === 'incoming' ? 'Incoming' : 'Outgoing' %> Messages</a></li>
    <li class="navBar__item"><a href="/portal/messages/<%= msg.id %>" class="navBar__link is-active">#<%= msg.id.substring(0,8) %></a></li>
  </ul>
</nav>

<div class="messageHeader">
  <div class="messageHeader__header messageHeader__header--<%= msg.scope || 'outgoing' %>">
    <p class="messageHeader__status"><span class="label label--messageStatus-<%= msg.status %>"><%= msg.status %></span></p>
    <h2 class="messageHeader__subject"><%= msg.subject || 'No subject' %></h2>
    <div class="messageHeader__basicProperties">
      <dl><dt>From</dt><dd><%= msg.mail_from || 'None' %></dd></dl>
      <dl><dt>To</dt><dd><%= msg.rcpt_to || 'None' %></dd></dl>
      <dl><dt>Received</dt><dd><%= new Date(msg.created_at).toLocaleString() %></dd></dl>
    </div>
  </div>
</div>

<nav class="navBar navBar--tertiary">
  <ul>
    <li class="navBar__item"><a href="/portal/messages/<%= msg.id %>" class="navBar__link <%= tab === 'properties' ? 'is-active' : '' %>">Properties</a></li>
    <li class="navBar__item"><a href="/portal/messages/<%= msg.id %>?tab=activity" class="navBar__link <%= tab === 'activity' ? 'is-active' : '' %>">Activity</a></li>
    <li class="navBar__item"><a href="/portal/messages/<%= msg.id %>?tab=headers" class="navBar__link <%= tab === 'headers' ? 'is-active' : '' %>">Headers</a></li>
    <li class="navBar__item"><a href="/portal/messages/<%= msg.id %>?tab=spam" class="navBar__link <%= tab === 'spam' ? 'is-active' : '' %>">Spam Checks</a></li>
    <li class="navBar__item"><a href="/portal/messages/<%= msg.id %>?tab=plain" class="navBar__link <%= tab === 'plain' ? 'is-active' : '' %>">Plain Text</a></li>
    <li class="navBar__item"><a href="/portal/messages/<%= msg.id %>?tab=html" class="navBar__link <%= tab === 'html' ? 'is-active' : '' %>">HTML</a></li>
    <li class="navBar__item"><a href="/portal/messages/<%= msg.id %>?tab=attachments" class="navBar__link <%= tab === 'attachments' ? 'is-active' : '' %>">Attachments</a></li>
    <% if (msg.raw_message || msg.raw_headers) { %>
      <li class="navBar__item"><a href="/portal/messages/<%= msg.id %>/download" class="navBar__link">Download</a></li>
    <% } %>
  </ul>
</nav>

<div class="pageContent">
  <% if (tab === 'properties') { %>
    <div class="messagePropertiesPage">
      <div class="messagePropertiesPage__left">
        <div class="messagePropertiesPage__propertyPair">
          <dl class="messagePropertiesPage__property">
            <dt>Spam Status</dt>
            <dd><span class="label label--large label--spamStatus-not_checked">Not checked</span></dd>
          </dl>
          <dl class="messagePropertiesPage__property">
            <dt>Tag</dt>
            <dd>Not tagged</dd>
          </dl>
        </div>
        <div class="messagePropertiesPage__propertyPair">
          <dl class="messagePropertiesPage__property">
            <dt>Raw Message</dt>
            <dd><%= msg.raw_headers ? 'Available' : 'Removed' %></dd>
          </dl>
          <dl class="messagePropertiesPage__property">
            <dt>Message Size</dt>
            <dd><%= msg.size ? (msg.size/1024).toFixed(1) + ' KB' : 'n/a' %></dd>
          </dl>
        </div>
        <div class="messagePropertiesPage__propertyPair">
          <dl class="messagePropertiesPage__property">
            <dt><%= msg.scope === 'incoming' ? 'Route' : 'Credential' %></dt>
            <dd><%= msg.credential_name || 'Unknown Credential' %></dd>
          </dl>
          <dl class="messagePropertiesPage__property">
            <dt>Domain</dt>
            <dd><%= msg.domain_name || 'Unknown Domain' %></dd>
          </dl>
        </div>
        <dl class="messagePropertiesPage__property">
          <dt>Message ID</dt>
          <dd><%= msg.message_id || 'No message ID' %></dd>
        </dl>
      </div>
      <div class="messagePropertiesPage__right">
        <h3 class="messagePropertiesPage__deliveriesTitle">Deliveries</h3>
        <% if (msg.deliveries && msg.deliveries.length > 0) { %>
          <ul class="deliveryList">
            <% msg.deliveries.forEach(function(d) { %>
              <li class="deliveryList__item">
                <div class="deliveryList__top">
                  <div class="deliveryList__time"><%= new Date(d.timestamp).toLocaleString() %></div>
                  <div class="deliveryList__status">
                    <% if (d.sent_with_ssl) { %><span class="deliveryList__secure" title="Delivered over SSL">&#128274;</span><% } %>
                    <span class="label label--large label--messageStatus-<%= d.status %>"><%= d.status %></span>
                  </div>
                </div>
                <% if (d.details) { %><p class="deliveryList__error"><%= d.details %></p><% } %>
                <div class="deliveryList__error deliveryList__error--output"><%= msg.mail_from %> &rarr; <%= d.rcpt_to %></div>
                <% if (d.output) { %>
                  <p class="deliveryList__techLink"><a href="javascript:toggleTech('<%= d.id %>')">Show technical details</a></p>
                  <div class="deliveryList__error deliveryList__error--output js-tech-output is-hidden" id="tech-<%= d.id %>" style="display:none">
                    <p><%= d.output %></p>
                    <% if (d.time) { %><p>Time: <%= d.time %>s</p><% } %>
                    <% if (d.log_id) { %><p>Support Ref: <%= d.log_id %></p><% } %>
                  </div>
                <% } %>
              </li>
            <% }) %>
          </ul>
        <% } else { %>
          <div class="noData noData--clean">
            <h2 class="noData__text">No delivery attempts yet.</h2>
          </div>
        <% } %>
      </div>
    </div>

  <% } else if (tab === 'activity') { %>
    <div class="tabular">
      <h3 style="font-size:16px;font-weight:600;margin-bottom:15px;">Activity Log</h3>
      <% if (msg.deliveries && msg.deliveries.length > 0) { %>
        <table class="table">
          <thead><tr><th>Time</th><th>Event</th><th>Details</th></tr></thead>
          <tbody>
            <% msg.deliveries.forEach(function(d) { %>
              <tr>
                <td><%= new Date(d.timestamp).toLocaleString() %></td>
                <td><span class="label label--messageStatus-<%= d.status %>"><%= d.status %></span></td>
                <td><%= d.details || '' %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } else { %>
        <div class="noData noData--clean">
          <h2 class="noData__text">No activity recorded yet.</h2>
        </div>
      <% } %>
    </div>

  <% } else if (tab === 'headers') { %>
    <div class="tabular">
      <h3 style="font-size:16px;font-weight:600;margin-bottom:15px;">Headers</h3>
      <pre class="mono" style="background:#f5f5f5;padding:12px;border-radius:3px;font-size:12px;overflow-x:auto;white-space:pre-wrap;word-break:break-all;"><%= msg.raw_headers || '(headers not available)' %></pre>
    </div>

  <% } else if (tab === 'spam') { %>
    <div class="tabular">
      <h3 style="font-size:16px;font-weight:600;margin-bottom:15px;">Spam Checks</h3>
      <div class="noData noData--clean">
        <h2 class="noData__text">No spam check results available.</h2>
      </div>
    </div>

  <% } else if (tab === 'plain') { %>
    <div class="tabular">
      <h3 style="font-size:16px;font-weight:600;margin-bottom:15px;">Plain Text</h3>
      <pre class="mono" style="background:#f5f5f5;padding:12px;border-radius:3px;font-size:12px;white-space:pre-wrap;"><%= msg.body_text || '(no plain text content)' %></pre>
    </div>

  <% } else if (tab === 'html') { %>
    <div class="tabular">
      <h3 style="font-size:16px;font-weight:600;margin-bottom:15px;">HTML</h3>
      <iframe srcdoc="<%= msg.body_html ? msg.body_html.replace(/"/g,'&quot;') : '' %>" style="width:100%;height:500px;border:1px solid #ddd;border-radius:3px;background:#fff;"></iframe>
    </div>

  <% } else if (tab === 'attachments') { %>
    <div class="tabular">
      <h3 style="font-size:16px;font-weight:600;margin-bottom:15px;">Attachments</h3>
      <div class="noData noData--clean">
        <h2 class="noData__text">No attachments.</h2>
      </div>
    </div>
  <% } %>
</div>

<script>
function toggleTech(id) {
  var el = document.getElementById('tech-' + id);
  if (el) el.style.display = el.style.display === 'none' ? 'block' : 'none';
}
</script>
