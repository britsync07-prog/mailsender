<div class="pageHeader">
  <div class="pageHeader__title">Domains</div>
</div>

<nav class="navBar">
  <ul>
    <li class="navBar__item"><a href="/portal/domains" class="navBar__link is-active">Domains</a></li>
    <li class="navBar__item navBar__item--end">
      <a href="javascript:showAddDomain()" class="navBar__link">+ Add Domain</a>
    </li>
  </ul>
</nav>

<div class="pageContent pageContent--sidebar">
  <div class="domainList">
    <% if (domains.length === 0) { %>
      <div class="noData">
        <div class="noData__title">No domains</div>
        <div class="noData__text">Add a domain to start sending email.</div>
        <div class="noData__button">
          <a href="javascript:showAddDomain()" class="button">Add Domain</a>
        </div>
      </div>
    <% } %>
    <% domains.forEach(function(d) { %>
      <div class="domainList__item">
        <div class="domainList__details">
          <div class="domainList__name">
            <%= d.domain %>
            <% if (d.verified) { %>
              <span class="label label--green">Verified</span>
            <% } else { %>
              <span class="label label--orange">Pending</span>
            <% } %>
          </div>
          <div class="domainList__checks">
            <span class="domainList__check domainList__check--<%= d.spf_status === 'ok' ? 'ok' : 'neutral' %>">SPF</span>
            <span class="domainList__check domainList__check--<%= d.dkim_status === 'ok' ? 'ok' : 'neutral' %>">DKIM</span>
            <span class="domainList__check domainList__check--<%= d.mx_status === 'ok' ? 'ok' : 'neutral' %>">MX</span>
            <span class="domainList__check domainList__check--<%= d.return_path_status === 'ok' ? 'ok' : 'neutral' %>">DMARC</span>
          </div>
        </div>
        <div class="domainList__properties">
          <div class="domainList__verificationTime">
            <% if (d.verified_at) { %>
              Verified <time><%= d.verified_at %></time>
            <% } else { %>
              Not verified
            <% } %>
          </div>
          <div class="domainList__links">
            <a href="javascript:verifyDomain('<%= d.id %>')" class="domainList__verificationLink">Verify DNS</a>
            <a href="javascript:deleteDomain('<%= d.id %>')" class="domainList__delete">Delete</a>
          </div>
        </div>
      </div>
    <% }) %>
  </div>
</div>

<!-- Add Domain Modal -->
<div id="domain-modal" class="modal" style="display:none">
  <div class="modal__backdrop" onclick="hideAddDomain()"></div>
  <div class="modal__content">
    <div class="modal__header">Add Domain</div>
    <div class="modal__body">
      <p>Enter the domain you want to send email from.</p>
      <div class="formBlock">
        <label>Domain</label>
        <input type="text" id="new-domain" placeholder="example.com">
      </div>
      <div id="domain-dns-records" style="display:none">
        <h3 style="font-size:14px;font-weight:600;margin-bottom:8px;">DNS Records</h3>
        <p style="font-size:12px;color:#999;margin-bottom:10px;">Add these DNS records to your domain provider's DNS settings:</p>
        <pre id="dns-records-output" class="mono" style="background:#f5f5f5;padding:12px;border-radius:3px;font-size:12px;overflow-x:auto;"></pre>
      </div>
    </div>
    <div class="modal__footer">
      <button class="button button--neutral" onclick="hideAddDomain()">Cancel</button>
      <button class="button" id="add-domain-btn" onclick="addDomain()">Add Domain</button>
    </div>
  </div>
</div>

<script>
function showAddDomain() { document.getElementById('domain-modal').style.display = 'flex'; }
function hideAddDomain() { document.getElementById('domain-modal').style.display = 'none'; }

async function addDomain() {
  var domain = document.getElementById('new-domain').value.trim();
  if (!domain) return alert('Enter a domain name');
  var btn = document.getElementById('add-domain-btn');
  btn.disabled = true; btn.textContent = 'Adding...';
  try {
    var res = await fetch('/api/portal/domains', { method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer <%= token %>' },
      body: JSON.stringify({ domain: domain })
    });
    var data = await res.json();
    if (!res.ok) return alert(data.error);
    document.getElementById('dns-records-output').textContent =
      'SPF: ' + data.dnsRecords.spf + '\nDKIM: ' + data.dnsRecords.dkim + '\nMX: ' + data.dnsRecords.mx;
    document.getElementById('domain-dns-records').style.display = 'block';
    document.getElementById('new-domain').disabled = true;
    btn.textContent = 'Close';
    btn.onclick = function() { location.reload(); };
  } catch(e) { alert('Error: ' + e.message); btn.disabled = false; btn.textContent = 'Add Domain'; }
}

async function verifyDomain(id) {
  var res = await fetch('/api/portal/domains/' + id + '/verify', {
    headers: { 'Authorization': 'Bearer <%= token %>' }
  });
  var data = await res.json();
  alert('Verification: ' + (data.verified ? 'ALL OK' : 'Some checks failed') + '\n\n' +
    'SPF: ' + data.checks.spf + '\nDKIM: ' + data.checks.dkim + '\nMX: ' + data.checks.mx + '\nDMARC: ' + data.checks.return_path);
  location.reload();
}

async function deleteDomain(id) {
  if (!confirm('Delete this domain?')) return;
  await fetch('/api/portal/domains/' + id, { method: 'DELETE',
    headers: { 'Authorization': 'Bearer <%= token %>' }
  });
  location.reload();
}
</script>
