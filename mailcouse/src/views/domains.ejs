<div class="pageHeader">
  <h1 class="pageHeader__title">
    <span class="pageHeader__titlePrevious">Organization &rarr;</span>
    Domains
  </h1>
</div>

<nav class="navBar navBar--secondary">
  <ul>
    <li class="navBar__item"><a href="/portal/domains" class="navBar__link is-active">Domains</a></li>
  </ul>
</nav>

<div class="pageContent pageContent--compact">
  <% if (domains.length === 0) { %>
    <div class="noData noData--clean">
      <h2 class="noData__title">There are no domains for this server.</h2>
      <p class="noData__text">To send &amp; receive messages you need to add &amp; verify the domain you wish to send/receive messages to/from. Add your domain below to get started.</p>
      <div class="noData__button"><a href="javascript:showAddDomain()" class="button button--positive">Add your first domain</a></div>
    </div>
  <% } else { %>
    <ul class="domainList u-margin">
      <% domains.forEach(function(d) { %>
        <li class="domainList__item">
          <div class="domainList__details">
            <p class="domainList__name">
              <%= d.domain %>
              <% if (d.verified) { %><span class="label label--green">Verified</span><% } else { %><span class="label label--orange">Pending</span><% } %>
            </p>
            <ul class="domainList__checks">
              <% if (d.spf_status === 'ok') { %><li class="domainList__check domainList__check--ok">SPF</li><% } else if (d.spf_status) { %><li class="domainList__check domainList__check--warning">SPF</li><% } %>
              <% if (d.dkim_status === 'ok') { %><li class="domainList__check domainList__check--ok">DKIM</li><% } else if (d.dkim_status) { %><li class="domainList__check domainList__check--warning">DKIM</li><% } %>
              <% if (d.mx_status === 'ok') { %><li class="domainList__check domainList__check--ok">MX</li><% } else if (d.mx_status) { %><li class="domainList__check domainList__check--neutral-cross">MX</li><% } %>
              <% if (d.return_path_status === 'ok') { %><li class="domainList__check domainList__check--ok">Return-Path</li><% } else if (d.return_path_status) { %><li class="domainList__check domainList__check--neutral">Return-Path</li><% } %>
            </ul>
          </div>
          <ul class="domainList__properties">
            <li class="domainList__verificationTime">
              <% if (d.verified) { %>Verified on <%= d.verified_at %><% } else { %><a href="javascript:verifyDomain('<%= d.id %>')" class="domainList__verificationLink">Verify this domain</a><% } %>
            </li>
            <li class="domainList__links">
              <a href="javascript:deleteDomain('<%= d.id %>')" class="domainList__delete">Delete</a>
            </li>
          </ul>
        </li>
      <% }) %>
    </ul>

    <p class="u-center buttonSet buttonSet--center">
      <a href="javascript:showAddDomain()" class="button button--positive">Add new domain</a>
    </p>
  <% } %>
</div>

<div id="domain-modal" class="modal" style="display:none">
  <div class="modal__backdrop" onclick="hideAddDomain()"></div>
  <div class="modal__content">
    <div class="modal__header">Add Domain</div>
    <div class="modal__body">
      <p>Enter the domain you want to send email from.</p>
      <div class="formBlock">
        <label>Domain</label>
        <input type="text" id="new-domain" placeholder="example.com">
      </div>
      <div id="domain-dns-records" style="display:none">
        <h3 style="font-size:14px;font-weight:600;margin-bottom:8px;">DNS Records</h3>
        <p style="font-size:12px;color:#999;margin-bottom:10px;">Add these DNS records to your domain provider's DNS settings:</p>
        <pre id="dns-records-output" class="mono codeBlock codeBlock--whitespace" style="white-space:pre-wrap;"></pre>
      </div>
    </div>
    <div class="modal__footer">
      <button class="button button--neutral" onclick="hideAddDomain()">Cancel</button>
      <button class="button button--positive" id="add-domain-btn" onclick="addDomain()">Add Domain</button>
    </div>
  </div>
</div>

<script>
function showAddDomain() { document.getElementById('domain-modal').style.display = 'flex'; }
function hideAddDomain() { document.getElementById('domain-modal').style.display = 'none'; }
async function addDomain() {
  var d = document.getElementById('new-domain').value.trim();
  if (!d) return alert('Enter a domain name');
  var btn = document.getElementById('add-domain-btn');
  btn.disabled = true; btn.textContent = 'Adding...';
  try {
    var r = await fetch('/api/portal/domains', { method: 'POST',
      headers: { 'Content-Type':'application/json','Authorization':'Bearer <%= token %>' },
      body: JSON.stringify({ domain: d })
    });
    var data = await r.json();
    if (!r.ok) return alert(data.error);
    document.getElementById('dns-records-output').textContent =
      'SPF: ' + data.dnsRecords.spf + '\nDKIM: ' + data.dnsRecords.dkim + '\nMX: ' + data.dnsRecords.mx;
    document.getElementById('domain-dns-records').style.display = 'block';
    document.getElementById('new-domain').disabled = true;
    btn.textContent = 'Close';
    btn.onclick = function() { location.reload(); };
  } catch(e) { alert('Error: ' + e.message); btn.disabled = false; btn.textContent = 'Add Domain'; }
}
async function verifyDomain(id) {
  var r = await fetch('/api/portal/domains/' + id + '/verify', { headers: { 'Authorization':'Bearer <%= token %>' } });
  var data = await r.json();
  alert('Verification: ' + (data.verified ? 'ALL OK' : 'Some checks failed') + '\n\nSPF: ' + data.checks.spf + '\nDKIM: ' + data.checks.dkim + '\nMX: ' + data.checks.mx + '\nDMARC: ' + data.checks.return_path);
  location.reload();
}
async function deleteDomain(id) {
  if (!confirm('Delete this domain?')) return;
  await fetch('/api/portal/domains/' + id, { method: 'DELETE', headers: { 'Authorization':'Bearer <%= token %>' } });
  location.reload();
}
</script>
