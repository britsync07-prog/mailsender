<!DOCTYPE html>
<html lang="en" class="main">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Mailcouse — <%= title %></title>
  <link href="https://fonts.googleapis.com/css2?family=Source+Sans+Pro:wght@300;400;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/postal.css">
  <link rel="stylesheet" href="//cdn.jsdelivr.net/chartist.js/latest/chartist.min.css">
</head>
<body>
  <header class="siteHeader" data-turbolinks-permanent>
    <div class="siteHeader__inside">
      <div class="siteHeader__logo"><a href="/portal/dashboard">Mailcouse</a></div>
      <div class="siteHeader__version">v1.0</div>
      <ul class="siteHeader__nav">
        <li class="siteHeader__navItem siteHeader__navItem--user"><%= email %></li>
        <li class="siteHeader__navItem"><a href="/portal/settings" class="sideHeader__navItemLink">My Settings</a></li>
        <li class="siteHeader__navItem"><a href="/logout" class="sideHeader__navItemLink">Logout</a></li>
      </ul>
    </div>
  </header>

  <div class="siteContent">
    <nav class="sidebar">
      <div class="sidebar__search">
        <input type="text" class="sidebar__searchInput" placeholder="Search servers or pages...">
      </div>
      <div class="sidebarServerList">
        <a href="/portal/dashboard" class="sidebarServerList__item <%= active === 'dashboard' ? 'is-active' : '' %>">
          <div class="sidebarServerList__name">Dashboard</div>
          <div class="sidebarServerList__meta">
            <span class="sidebarServerList__mode"><span class="label label--serverStatus-live">Live</span></span>
          </div>
        </a>
        <a href="/portal/domains" class="sidebarServerList__item <%= active === 'domains' ? 'is-active' : '' %>">
          <div class="sidebarServerList__name">Domains</div>
          <div class="sidebarServerList__meta">
            <span class="sidebarServerList__mode"><span class="label label--serverStatus-live">Live</span></span>
          </div>
        </a>
        <a href="/portal/credentials" class="sidebarServerList__item <%= active === 'credentials' ? 'is-active' : '' %>">
          <div class="sidebarServerList__name">Credentials</div>
          <div class="sidebarServerList__meta">
            <span class="sidebarServerList__mode"><span class="label label--serverStatus-live">Live</span></span>
          </div>
        </a>
        <a href="/portal/messages" class="sidebarServerList__item <%= active === 'messages' ? 'is-active' : '' %>">
          <div class="sidebarServerList__name">Messages</div>
          <div class="sidebarServerList__meta">
            <span class="sidebarServerList__mode"><span class="label label--serverStatus-live">Live</span></span>
          </div>
        </a>
        <a href="/portal/routes" class="sidebarServerList__item <%= active === 'routes' ? 'is-active' : '' %>">
          <div class="sidebarServerList__name">Routes</div>
          <div class="sidebarServerList__meta">
            <span class="sidebarServerList__mode"><span class="label label--serverStatus-development">Dev</span></span>
          </div>
        </a>
        <a href="/portal/webhooks" class="sidebarServerList__item <%= active === 'webhooks' ? 'is-active' : '' %>">
          <div class="sidebarServerList__name">Webhooks</div>
          <div class="sidebarServerList__meta">
            <span class="sidebarServerList__mode"><span class="label label--serverStatus-development">Dev</span></span>
          </div>
        </a>
        <a href="/portal/track-domains" class="sidebarServerList__item <%= active === 'track-domains' ? 'is-active' : '' %>">
          <div class="sidebarServerList__name">Track Domains</div>
          <div class="sidebarServerList__meta">
            <span class="sidebarServerList__mode"><span class="label label--serverStatus-development">Dev</span></span>
          </div>
        </a>
      </div>
      <div class="sidebar__new">
        <a href="/portal/domains" class="u-link">+ Add new domain</a>
      </div>
    </nav>
    <section class="siteContent__main">
      <%- body %>
      <footer class="siteContent__footer">
        <ul class="footer__links">
          <li class="footer__name">Powered by Mailcouse v1.0</li>
          <li><a href="https://docs.postalserver.io" target="_blank">Documentation</a></li>
          <li><a href="https://discussions.postalserver.io" target="_blank">Ask for help</a></li>
        </ul>
      </footer>
    </section>
  </div>

  <script src="//cdn.jsdelivr.net/chartist.js/latest/chartist.min.js"></script>
  <script>
    document.querySelectorAll('[data-chart]').forEach(function(el) {
      try {
        var data = JSON.parse(el.getAttribute('data-chart-data') || '{}');
        var opts = JSON.parse(el.getAttribute('data-chart-options') || '{}');
        new Chartist[el.getAttribute('data-chart')](el, data, opts);
      } catch(e) { console.warn('Chart error:', e); }
    });
  </script>
  <%- script %>
</body>
</html>
