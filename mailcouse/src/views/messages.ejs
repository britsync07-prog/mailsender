<div class="pageHeader">
  <div class="pageHeader__title">Messages</div>
</div>

<nav class="navBar navBar--secondary">
  <ul>
    <li class="navBar__item"><a href="/portal/messages" class="navBar__link is-active">Outgoing Messages</a></li>
  </ul>
</nav>

<div class="pageContent js-ajax-region">
  <div class="messageSearch">
    <a href="javascript:toggleHelp()" class="messageSearch__help js-toggle-helpbox">Need help searching?</a>
    <input type="text" class="messageSearch__input js-focus-on-f" placeholder="Search messages..." id="message-search-input" value="<%= search %>" onkeydown="if(event.key==='Enter')searchMessages()">
    <div class="messageSearch__helpBox is-hidden js-helpbox" id="search-help" style="display:none">
      <div class="messageSearch__left">
        <h3 class="messageSearch__helpBoxTitle">Searching messages</h3>
        <p class="messageSearch__helpBoxText">You can use the following keywords to narrow down your search results:</p>
      </div>
      <div class="messageSearch__right">
        <dl class="messageSearch__definition">
          <dt>to:<em>email</em></dt>
          <dd>Search for messages sent to a specific address</dd>
        </dl>
        <dl class="messageSearch__definition">
          <dt>from:<em>email</em></dt>
          <dd>Search for messages sent from a specific address</dd>
        </dl>
        <dl class="messageSearch__definition">
          <dt>subject:<em>text</em></dt>
          <dd>Search for messages with a specific word in the subject</dd>
        </dl>
      </div>
    </div>
  </div>

  <% if (messages.length === 0) { %>
    <% if (search || status) { %>
      <div class="noData noData--clean">
        <h2 class="noData__title">No messages found matching your filter.</h2>
        <p class="noData__text">There were no messages which matched the query that you entered. Sorry about that.</p>
      </div>
    <% } else { %>
      <div class="pageContent--compact">
        <div class="noData noData--clean">
          <h2 class="noData__title">No messages have been sent yet.</h2>
          <p class="noData__text">You haven't sent any messages through this mail server yet. Not to worry though — they'll start appearing here as soon as you start sending them.</p>
        </div>
      </div>
    <% } %>
  <% } else { %>
    <div class="messageList">
      <% messages.forEach(function(m) { %>
        <div class="messageList__message">
          <a href="/portal/messages/<%= m.id %>" class="messageList__link">
            <div class="messageList__details messageList__details--outgoing">
              <p class="messageList__subject"><%= m.subject || '(no subject)' %></p>
              <dl class="messageList__addresses">
                <dt>To:</dt><dd><%= m.rcpt_to %></dd>
                <dt>From:</dt><dd><%= m.mail_from %></dd>
              </dl>
            </div>
            <div class="messageList__meta">
              <p class="messageList__timestamp"><%= m.created_at %></p>
              <p class="messageList__status"><span class="label label--messageStatus-<%= m.status %>"><%= m.status %></span></p>
            </div>
          </a>
        </div>
      <% }) %>
    </div>

    <% if (pagination && pagination.totalPages > 1) { %>
      <div class="simplePagination">
        <p class="simplePagination__previous">
          <% if (pagination.page > 1) { %><a href="?page=<%= pagination.page - 1 %><%= status ? '&status=' + status : '' %><%= search ? '&search=' + search : '' %>" class="simplePagination__link">&larr; Previous</a><% } %>
        </p>
        <div class="simplePagination__current">
          <p class="simplePagination__info"><%= pagination.total %> messages</p>
          <p>Page <%= pagination.page %> of <%= pagination.totalPages %></p>
        </div>
        <p class="simplePagination__next">
          <% if (pagination.page < pagination.totalPages) { %><a href="?page=<%= pagination.page + 1 %><%= status ? '&status=' + status : '' %><%= search ? '&search=' + search : '' %>" class="simplePagination__link">Next &rarr;</a><% } %>
        </p>
      </div>
    <% } %>
  <% } %>
</div>

<script>
function toggleHelp() {
  var h = document.getElementById('search-help');
  h.style.display = h.style.display === 'none' ? 'flex' : 'none';
}
function searchMessages() {
  var s = document.getElementById('message-search-input').value;
  location.href = '/portal/messages?search=' + encodeURIComponent(s);
}
</script>
